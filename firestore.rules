rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    // Schema Validations
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'username', 'email'])
        && data.uid == request.auth.uid
        && data.username is string && data.username.size() >= 3 && data.username.size() <= 30
        && data.email is string && data.email.size() <= 255;
    }

    function isValidSong(data) {
      return data.title is string && data.title.size() <= 200
        && data.artistName is string && data.artistName.size() <= 200;
    }

    function isValidPlaylist(data) {
      return data.keys().hasAll(['name', 'ownerId'])
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.ownerId == request.auth.uid;
    }

    // --- Collections ---

    // Users
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && resource.data.isPublic == true;
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) 
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['username', 'avatarUrl', 'bio', 'likedSongs', 'savedAlbums', 'followedArtists', 'isPublic'])
        && (request.resource.data.username == resource.data.username || request.resource.data.username.size() >= 3);
    }

    // Songs (Read only for users, admin for write)
    match /songs/{songId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Albums
    match /albums/{albumId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Artists
    match /artists/{artistId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Playlists
    match /playlists/{playlistId} {
      allow read: if isSignedIn() && (resource.data.isPublic == true || resource.data.ownerId == request.auth.uid || request.auth.uid in resource.data.collaboratorIds);
      allow create: if isSignedIn() && isValidPlaylist(request.resource.data);
      allow update: if isSignedIn() && (
        // Owner can update anything
        (resource.data.ownerId == request.auth.uid && request.resource.data.ownerId == resource.data.ownerId)
        || 
        // Collaborators can only update songs
        (request.auth.uid in resource.data.collaboratorIds && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['songIds']))
      );
      allow delete: if isOwner(resource.data.ownerId);
    }

    // Interactions
    match /interactions/{interactionId} {
      allow create: if isSignedIn() && request.resource.data.fromUserId == request.auth.uid;
      allow read, delete: if isSignedIn() && resource.data.fromUserId == request.auth.uid;
    }

    // History
    match /history/{historyId} {
      allow read, create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }
  }
}
